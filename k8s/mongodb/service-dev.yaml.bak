# ─────────────────────────────────────────────────────────────
# WellNest — MongoDB Services (Headless + ClusterIP)
# Environment: dev
# Namespace: wellnest-dev
# Phase: 2 — Kubernetes Manifests
# ─────────────────────────────────────────────────────────────
# Two services:
#   1. mongodb-headless — clusterIP: None for StatefulSet DNS
#      Provides stable DNS: mongodb-{0,1,2}.mongodb-headless.<ns>.svc
#      publishNotReadyAddresses: true ensures DNS works during init
#   2. mongodb — standard ClusterIP for general access
# ─────────────────────────────────────────────────────────────

apiVersion: v1
kind: Service
metadata:
  name: mongodb-headless
  namespace: wellnest-dev
  labels:
    app: mongodb
    app.kubernetes.io/part-of: wellnest
    app.kubernetes.io/managed-by: kubectl
    environment: dev
spec:
  clusterIP: None
  publishNotReadyAddresses: true
  selector:
    app: mongodb
  ports:
    - name: mongodb
      port: 27017
      targetPort: 27017

---

apiVersion: v1
kind: Service
metadata:
  name: mongodb
  namespace: wellnest-dev
  labels:
    app: mongodb
    app.kubernetes.io/part-of: wellnest
    app.kubernetes.io/managed-by: kubectl
    environment: dev
spec:
  type: ClusterIP
  selector:
    app: mongodb
  ports:
    - name: mongodb
      port: 27017
      targetPort: 27017
