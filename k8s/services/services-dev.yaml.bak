# ─────────────────────────────────────────────────────────────
# WellNest — All ClusterIP Services (backend + frontend)
# Environment: dev
# Namespace: wellnest-dev
# Phase: 2 — Kubernetes Manifests
# ─────────────────────────────────────────────────────────────
# Five services:
#   1. auth-service        → port 3001
#   2. assessment-service  → port 3002
#   3. therapist-service   → port 3003
#   4. frontend-active     → port 80 (live traffic)
#   5. frontend-preview    → port 80 (blue-green preview)
# ─────────────────────────────────────────────────────────────

apiVersion: v1
kind: Service
metadata:
  name: auth-service
  namespace: wellnest-dev
  labels:
    app: auth-service
    app.kubernetes.io/part-of: wellnest
    app.kubernetes.io/managed-by: kubectl
    environment: dev
spec:
  type: ClusterIP
  selector:
    app: auth-service
  ports:
    - name: http
      port: 3001
      targetPort: 3001
      protocol: TCP

---

apiVersion: v1
kind: Service
metadata:
  name: assessment-service
  namespace: wellnest-dev
  labels:
    app: assessment-service
    app.kubernetes.io/part-of: wellnest
    app.kubernetes.io/managed-by: kubectl
    environment: dev
spec:
  type: ClusterIP
  selector:
    app: assessment-service
  ports:
    - name: http
      port: 3002
      targetPort: 3002
      protocol: TCP

---

apiVersion: v1
kind: Service
metadata:
  name: therapist-service
  namespace: wellnest-dev
  labels:
    app: therapist-service
    app.kubernetes.io/part-of: wellnest
    app.kubernetes.io/managed-by: kubectl
    environment: dev
spec:
  type: ClusterIP
  selector:
    app: therapist-service
  ports:
    - name: http
      port: 3003
      targetPort: 3003
      protocol: TCP

---

# frontend-active receives LIVE production traffic.
# Argo Rollouts manages the selector on this service
# to point to the active ReplicaSet.
apiVersion: v1
kind: Service
metadata:
  name: frontend-active
  namespace: wellnest-dev
  labels:
    app: frontend
    app.kubernetes.io/part-of: wellnest
    app.kubernetes.io/managed-by: kubectl
    environment: dev
spec:
  type: ClusterIP
  selector:
    app: frontend
  ports:
    - name: http
      port: 80
      targetPort: 80
      protocol: TCP

---

# frontend-preview receives PREVIEW traffic during blue-green
# rollout. Used to test the new version before promotion.
apiVersion: v1
kind: Service
metadata:
  name: frontend-preview
  namespace: wellnest-dev
  labels:
    app: frontend
    app.kubernetes.io/part-of: wellnest
    app.kubernetes.io/managed-by: kubectl
    environment: dev
spec:
  type: ClusterIP
  selector:
    app: frontend
  ports:
    - name: http
      port: 80
      targetPort: 80
      protocol: TCP
