# ─────────────────────────────────────────────────────────────
# WellNest — All ClusterIP Services (backend + frontend)
# Environment: prod
# Namespace: wellnest-prod
# Phase: 2 — Kubernetes Manifests
# ─────────────────────────────────────────────────────────────

apiVersion: v1
kind: Service
metadata:
  name: auth-service
  namespace: wellnest-prod
  labels:
    app: auth-service
    app.kubernetes.io/part-of: wellnest
    app.kubernetes.io/managed-by: kubectl
    environment: prod
spec:
  type: ClusterIP
  selector:
    app: auth-service
  ports:
    - name: http
      port: 3001
      targetPort: 3001
      protocol: TCP

---

apiVersion: v1
kind: Service
metadata:
  name: assessment-service
  namespace: wellnest-prod
  labels:
    app: assessment-service
    app.kubernetes.io/part-of: wellnest
    app.kubernetes.io/managed-by: kubectl
    environment: prod
spec:
  type: ClusterIP
  selector:
    app: assessment-service
  ports:
    - name: http
      port: 3002
      targetPort: 3002
      protocol: TCP

---

apiVersion: v1
kind: Service
metadata:
  name: therapist-service
  namespace: wellnest-prod
  labels:
    app: therapist-service
    app.kubernetes.io/part-of: wellnest
    app.kubernetes.io/managed-by: kubectl
    environment: prod
spec:
  type: ClusterIP
  selector:
    app: therapist-service
  ports:
    - name: http
      port: 3003
      targetPort: 3003
      protocol: TCP

---

apiVersion: v1
kind: Service
metadata:
  name: frontend-active
  namespace: wellnest-prod
  labels:
    app: frontend
    app.kubernetes.io/part-of: wellnest
    app.kubernetes.io/managed-by: kubectl
    environment: prod
spec:
  type: ClusterIP
  selector:
    app: frontend
  ports:
    - name: http
      port: 80
      targetPort: 80
      protocol: TCP

---

apiVersion: v1
kind: Service
metadata:
  name: frontend-preview
  namespace: wellnest-prod
  labels:
    app: frontend
    app.kubernetes.io/part-of: wellnest
    app.kubernetes.io/managed-by: kubectl
    environment: prod
spec:
  type: ClusterIP
  selector:
    app: frontend
  ports:
    - name: http
      port: 80
      targetPort: 80
      protocol: TCP
