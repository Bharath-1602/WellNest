# ─────────────────────────────────────────────────────────────
# WellNest — ConfigMap for non-secret configuration (dev)
# Environment: dev
# Namespace: wellnest-dev
# Phase: 2 — Kubernetes Manifests
# ─────────────────────────────────────────────────────────────
# Contains all non-sensitive environment variables shared
# across backend services. Secrets (passwords, tokens) are
# stored separately in SealedSecrets.
# ─────────────────────────────────────────────────────────────

apiVersion: v1
kind: ConfigMap
metadata:
  name: wellnest-config
  namespace: wellnest-dev
  labels:
    app.kubernetes.io/part-of: wellnest
    app.kubernetes.io/managed-by: kubectl
    environment: dev
data:
  NODE_ENV: "development"
  LOG_LEVEL: "debug"

  AUTH_SERVICE_PORT: "3001"
  ASSESSMENT_SERVICE_PORT: "3002"
  THERAPIST_SERVICE_PORT: "3003"
  FRONTEND_PORT: "80"

  AUTH_SERVICE_URL: >-
    http://auth-service.wellnest-dev.svc.cluster.local:3001
  ASSESSMENT_SERVICE_URL: >-
    http://assessment-service.wellnest-dev.svc.cluster.local:3002
  THERAPIST_SERVICE_URL: >-
    http://therapist-service.wellnest-dev.svc.cluster.local:3003

  MONGODB_HOST: >-
    mongodb-0.mongodb-headless.wellnest-dev.svc.cluster.local
  MONGODB_PORT: "27017"
  MONGODB_DATABASE: "wellnest"
  MONGODB_REPLICA_SET: "rs0"

  FRONTEND_URL: "http://wellnest-dev.local"

  JWT_EXPIRY: "24h"
  JWT_ALGORITHM: "HS256"

  RUN_SEED: "true"
