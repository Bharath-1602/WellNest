# ─────────────────────────────────────────────────────────────
# WellNest — Frontend Argo Rollout (Blue-Green) + AnalysisTemplate
# Environment: dev
# Namespace: wellnest-dev
# Phase: 2 — Kubernetes Manifests
# ─────────────────────────────────────────────────────────────
# ─── REPLACE BEFORE APPLYING ─────────────────────────────────
# bharath44623 → your DockerHub username
# ─────────────────────────────────────────────────────────────
# Uses Argo Rollouts Blue-Green strategy instead of a standard
# Deployment. Two services are required:
#   frontend-active  — receives live production traffic
#   frontend-preview — receives preview traffic during rollout
# autoPromotionEnabled: false — requires manual promotion
# ─────────────────────────────────────────────────────────────

apiVersion: argoproj.io/v1alpha1
kind: Rollout
metadata:
  name: frontend
  namespace: wellnest-dev
  labels:
    app: frontend
    app.kubernetes.io/part-of: wellnest
    app.kubernetes.io/managed-by: kubectl
    environment: dev
spec:
  replicas: 1
  selector:
    matchLabels:
      app: frontend
  template:
    metadata:
      labels:
        app: frontend
        environment: dev
    spec:
      securityContext:
        runAsNonRoot: true
        runAsUser: 101
        runAsGroup: 101
        fsGroup: 101

      containers:
        - name: frontend
          image: docker.io/bharath44623/wellnest-frontend:dev
          imagePullPolicy: Always
          ports:
            - containerPort: 80
              name: http
              protocol: TCP

          resources:
            requests:
              cpu: "50m"
              memory: "64Mi"
            limits:
              cpu: "200m"
              memory: "128Mi"

          livenessProbe:
            httpGet:
              path: /
              port: 80
            initialDelaySeconds: 15
            periodSeconds: 20
            timeoutSeconds: 5
            failureThreshold: 3
            successThreshold: 1

          readinessProbe:
            httpGet:
              path: /
              port: 80
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
            successThreshold: 1

          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop: ["ALL"]
              add: ["NET_BIND_SERVICE"]

  strategy:
    blueGreen:
      activeService: frontend-active
      previewService: frontend-preview
      autoPromotionEnabled: false
      scaleDownDelaySeconds: 30
      previewReplicaCount: 1

---

# ─────────────────────────────────────────────────────────────
# AnalysisTemplate — Health check for Blue-Green preview
# Runs curl against frontend-preview service to verify the
# new version responds with HTTP 200 before promotion.
# ─────────────────────────────────────────────────────────────

apiVersion: argoproj.io/v1alpha1
kind: AnalysisTemplate
metadata:
  name: frontend-health-check
  namespace: wellnest-dev
  labels:
    app: frontend
    app.kubernetes.io/part-of: wellnest
    environment: dev
spec:
  metrics:
    - name: health-check
      interval: 10s
      count: 3
      successCondition: result == "ok"
      failureLimit: 1
      provider:
        job:
          spec:
            template:
              spec:
                restartPolicy: Never
                containers:
                  - name: health-checker
                    image: curlimages/curl:latest
                    command:
                      - sh
                      - -c
                      - |
                        STATUS=$(curl -s -o /dev/null -w "%{http_code}" \
                          http://frontend-preview.wellnest-dev.svc.cluster.local:80)
                        if [ "$STATUS" = "200" ]; then
                          echo "ok"
                        else
                          echo "fail"
                          exit 1
                        fi
